# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/santepublique_aof
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/santepublique_aof

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase Auth (get from https://app.supabase.com/project/YOUR_PROJECT/settings/api)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI Embeddings
OPENAI_API_KEY=sk-your-key

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# Next.js (NEXT_PUBLIC_ prefix = exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OAuth Provider Settings (configured in Supabase Dashboard)
# Google OAuth: https://console.cloud.google.com/
# LinkedIn OAuth: https://developer.linkedin.com/
# These don't need environment variables - configured in Supabase Auth settings

# Rate Limiting & Security
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_TUTOR_MESSAGES_PER_DAY=50
