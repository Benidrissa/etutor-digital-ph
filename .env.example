# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/santepublique_aof
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/santepublique_aof

# Redis
REDIS_URL=redis://localhost:6379/0

# Local JWT Auth
JWT_SECRET=your-secret-key-change-in-production

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI Embeddings
OPENAI_API_KEY=sk-your-key

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# App
APP_ENV=development
# For production, set CORS_ORIGINS to a comma-separated list of allowed frontend origins.
# Example: CORS_ORIGINS=https://etutor.elearning.portfolio2.kimbetien.com,https://other.domain.com
CORS_ORIGINS=http://localhost:3000
API_V1_PREFIX=/api/v1

# Next.js (NEXT_PUBLIC_ prefix = exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email Service
RESEND_API_KEY=re_your-key
FROM_EMAIL=noreply@santepublique-aof.org
FRONTEND_URL=http://localhost:3000

# Monitoring — Sentry (empty = disabled in dev)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Monitoring — PostHog (EU instance for GDPR, empty = disabled in dev)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# MinIO / S3-compatible object storage
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# Rate Limiting & Security
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_TUTOR_MESSAGES_PER_DAY=50
